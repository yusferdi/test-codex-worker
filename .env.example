API_BASE_URL=http://localhost:8000/api
WORKER_API_KEY=ganti-dengan-key-yang-sama-dengan-api
WORKER_NAME=worker-local

# puppeteer: login lewat browser lokal; direct/login-direct: login lewat API SIKS tanpa Chrome.
SIKS_AUTH_MODE=puppeteer

# Wajib hanya untuk SIKS_AUTH_MODE=puppeteer.
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
HEADLESS=false
# true: browser/session dipakai ulang antar-job; false: browser ditutup setiap job.
KEEP_BROWSER_OPEN=true
# true hanya untuk debugging lokal bila Chrome harus tetap terbuka saat worker berhenti.
LEAVE_BROWSER_OPEN_ON_EXIT=false
SIKS_USER_DATA_DIR=./session-data

SIKS_USERNAME=
SIKS_PASSWORD=
SIKS_ACTION_TIMEOUT_MS=10000
SIKS_SEARCH_TIMEOUT_MS=15000
SIKS_CAPTCHA_ATTEMPTS=5
SIKS_AUTH_API_BASE_URL=https://api.kemensos.go.id
SIKS_AUTH_APP_KEY=base64:DuwlELKGgZKS0EO64/5ROG0UEy84IiebaIoNLAi0bFU=
SIKS_AUTH_TIMEOUT_MS=30000
SIKS_HTTP_LOGIN_USERNAME_FIELD=email
# true: tampilkan log detail auth direct meskipun LOG_LEVEL bukan verbose.
SIKS_DIRECT_DEBUG_AUTH=false
# true/verbose: captcha dan OTP ikut tampil di log direct auth. Hati-hati untuk log publik.
SIKS_DIRECT_VERBOSE_SECRETS=false
# Override darurat untuk mode direct/login-direct bila captcha/OTP mau diisi manual.
SIKS_HTTP_LOGIN_CAPTCHA=
SIKS_HTTP_LOGIN_OTP=
# Paksa buka DTSEN berkala agar sesi semu/kedaluwarsa terdeteksi sebelum row diproses.
SIKS_SESSION_PROBE_INTERVAL_MS=120000
SIKS_SESSION_SETTLE_MS=2000
SIKS_SESSION_RECOVERY_ATTEMPTS=2
SIKS_SESSION_RECOVERY_DELAY_MS=1500
# Hanya membersihkan cookie/storage domain Kemensos, tidak mengeluarkan Telegram.
SIKS_CLEAR_AUTH_STATE_ON_RECOVERY=true
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_API_MODEL=gemini-2.5-flash
GEMINI_REQUEST_TIMEOUT_MS=30000
GEMINI_KEY_COOLDOWN_MS=60000
CAPTCHA_PATTERN=([A-Z]{3}[0-9])
CAPTCHA_LENGTH=4

# OTP via Telegram Web, dipakai oleh mode puppeteer.
TELEGRAM_OTP_URL=
TELEGRAM_MESSAGE_SELECTOR=div.message-content-wrapper.can-select-text div.content-inner > div
TELEGRAM_GO_TO_BOTTOM_SELECTOR=button[aria-label="Go to bottom"], button[title="Go to bottom"]
TELEGRAM_GO_TO_BOTTOM_TEXTS=go to bottom,scroll to bottom,jump to bottom,pesan terbaru,ke bawah
TELEGRAM_OTP_PREFIX=Kode OTP:
TELEGRAM_OTP_WAIT_TIMEOUT_MS=60000
TELEGRAM_OTP_READ_ATTEMPTS=5
# Setelah OTP ditolak, tunggu dan klik/scroll sampai kode berbeda muncul.
TELEGRAM_NEW_OTP_WAIT_ATTEMPTS=30
TELEGRAM_SCROLL_ATTEMPTS=6
TELEGRAM_SETTLE_SCROLL_ATTEMPTS=3

# OTP via Telegram API/GramJS, dipakai oleh mode direct/login-direct.
# Jalankan sekali dari folder worker: npm run telegram:setup
TELEGRAM_ENABLED=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_FILE=.siks/telegram.session
TELEGRAM_OTP_CHAT=
TELEGRAM_OTP_REGEX=\b\d{6}\b
TELEGRAM_OTP_TIMEOUT_MS=60000
TELEGRAM_OTP_INTERVAL_MS=3000
TELEGRAM_OTP_LIMIT=15
TELEGRAM_DIALOG_LIMIT=20

SIKS_OTP_SUBMIT_ATTEMPTS=20
SIKS_OTP_RETRY_DELAY_MS=1500

# Override ini dipakai kalau label/teks/selector halaman SIKS berubah.
SIKS_DETAIL_TITLE_TEXT=Detail Data DTSEN
SIKS_RIWAYAT_TEXT=Riwayat Bansos
SIKS_NO_RIWAYAT_TEXT=Tidak Ada Riwayat Penerimaan Bansos
SIKS_RIWAYAT_PKH_TEXT=PKH
SIKS_RIWAYAT_SEMBAKO_TEXT=SEMBAKO
SIKS_RIWAYAT_PBI_TEXT=PBI
SIKS_PKH_PERIOD_TEXT=PKH OKT - DES 2025
SIKS_SEMBAKO_PERIOD_TEXT=SEMBAKO OKT - DES 2025
SIKS_PBI_PROGRAM_TEXT=PBI JKN
SIKS_PBI_START_YEAR=2025
SIKS_PBI_END_YEAR=2026
SIKS_PBI_END_MONTHS=JANUARI,FEBRUARI
SIKS_PBI_FLAG_VALUE=PBI januari
SIKS_OTP_VALIDATION_SELECTORS=button#\:rf\:,button[type="button"]#\:rf\:

API_REQUEST_TIMEOUT_MS=60000
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY_MS=1500
API_FALLBACK_DIR=./output/api-fallback

ROW_TIMEOUT_MS=300000
ROW_RETRY_ATTEMPTS=2
# Extra check sebelum row boleh tetap berstatus ERROR pada hasil final.
ROW_ERROR_RECHECK_ATTEMPTS=2
ROW_ERROR_RECHECK_DELAY_MS=1500
# Hasil partial yang masih memiliki status ERROR diperiksa ulang sebelum complete.
RECHECK_ERROR_ROWS_BEFORE_COMPLETE=true
MAX_CONSECUTIVE_ROW_ERRORS=30
RESUME_PARTIAL_RESULTS=true
REQUEUE_ON_SHUTDOWN=true
RUN_ONCE=false
MAX_JOBS_PER_RUN=0
